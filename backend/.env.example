# ForgeMind Backend — Environment Variable Template
#
# Copy this file to `.env` and fill in real values for local development:
#   cp .env.example .env
#
# NEVER commit the actual `.env` file — only this template. `.env` is
# already excluded via .gitignore.

# ------------------------------------------------------------------
# General application metadata
# ------------------------------------------------------------------
APP_NAME=ForgeMind
APP_DESCRIPTION="ForgeMind Enterprise Intelligence Platform API"
APP_VERSION=0.1.0

# One of: local, development, staging, production
ENVIRONMENT=local

# Never set to true in production
DEBUG=true

# ------------------------------------------------------------------
# Server configuration
# ------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# ------------------------------------------------------------------
# API versioning
# ------------------------------------------------------------------
API_V1_PREFIX=/api/v1

# ------------------------------------------------------------------
# CORS configuration
# ------------------------------------------------------------------
# Comma-separated list of allowed frontend origins.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
